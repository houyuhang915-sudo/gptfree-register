FREE_CONSOLE_HOST=0.0.0.0
FREE_CONSOLE_PORT=8866
FREE_CONSOLE_PUBLISH_PORT=8866
FREE_CONSOLE_BIND_ADDRESS=127.0.0.1
FREE_CONSOLE_PASSWORD=
FREE_CONSOLE_THREADS=8
TZ=Asia/Shanghai
FREE_CONSOLE_TIMEZONE=Asia/Shanghai

# Free / OpenAI SMS pool
FREE_SMS_PROVIDER=smsbower
FREE_SMSBOWER_API_KEY=
FREE_SMSBOWER_BASE_URL=https://smsbower.app/stubs/handler_api.php
FREE_SMSBOWER_SERVICE=dr
FREE_SMSBOWER_COUNTRY=12
FREE_SMSBOWER_MAX_PRICE=
FREE_SMSBOWER_USE_V2=1

# Managed 711-compatible proxy pool
PROXY_HOST=
PROXY_PORT=10000
PROXY_USER=
PROXY_PASS=

# Optional Sub2API Agent Identity delivery
GATEWAY_SUB2API_URL=
GATEWAY_SUB2API_TOKEN=
GATEWAY_SUB2API_AGENT_PATH=/api/v1/admin/accounts/import/codex-session
GATEWAY_SUB2API_GROUP_IDS=2

# Browser mode runs on the host by default; protocol mode is server-friendly.
BITBROWSER_API=http://127.0.0.1:54345
ROXY_API_PORT=50000
ROXY_API_TOKEN=
CHROME_PATH=/usr/bin/chromium
