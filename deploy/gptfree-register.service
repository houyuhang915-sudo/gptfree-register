[Unit]
Description=gptfree-register
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=freeops
Group=freeops
WorkingDirectory=/opt/gptfree-register
EnvironmentFile=-/opt/gptfree-register/.env
ExecStart=/opt/gptfree-register/start.sh
Restart=always
RestartSec=3
KillMode=mixed
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
