server {
    listen 80;
    server_name gptfree-register.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name gptfree-register.example.com;

    ssl_certificate /etc/letsencrypt/live/gptfree-register.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gptfree-register.example.com/privkey.pem;

    client_max_body_size 2m;
    proxy_read_timeout 3600s;

    location / {
        proxy_pass http://127.0.0.1:8866;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
